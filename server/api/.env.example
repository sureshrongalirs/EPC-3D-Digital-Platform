# Where uploaded/converted model artifacts live on disk (CLAUDE.md invariant #5: the
# database stores only pointers, never blobs). In docker-compose this is /data.
DATA_DIR=./data

# postgres://user:pass@host:5432/db for Postgres, or a filesystem path for the bundled
# SQLite adapter (local dev only — see CLAUDE.md's storage-interface note in src/db).
DATABASE_URL=./data/dev.sqlite3

# Real sources run 200MB+ FBX / 800MB+ .mdb2 (CLAUDE.md invariant #4) — do not lower this
# without checking against real fixture sizes.
MAX_UPLOAD_MB=1024

PORT=3000
