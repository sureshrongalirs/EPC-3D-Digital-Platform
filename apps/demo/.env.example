# Real Cesium Ion access token for the 3D globe view's terrain/imagery. Optional -- if
# unset, the `cesium` npm package's bundled evaluation-only demo token is used instead (see
# @plantscope/globe-view's providerConfig.ts and CLAUDE.md's "Rendering surfaces" note for
# why that's fine for local dev but not for production).
VITE_CESIUM_ION_TOKEN=your_token_here
